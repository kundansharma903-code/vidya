## 2. DATABASE SCHEMA

### 2.1 All 25 Tables

**Foundation tables (multi-tenancy):**
1. `institutes` - Tenant entity
2. `users` - All 6 roles
3. `institute_settings` - Tenant config

**Academic structure:**
4. `courses` - NEET, IIT-JEE
5. `batches` - Morning A, Evening B, etc.
6. `students` - Individual students
7. `subjects` - Physics, Chemistry, etc.
8. `curriculum_nodes` - Topic tree (Chapter→Topic→Subtopic)

**Assignments:**
9. `user_batch_assignments` - Teacher↔Batch
10. `user_subject_assignments` - Teacher↔Subject
11. `sub_admin_permissions` - Granular permissions

**Testing:**
12. `tests` - Test metadata
13. `test_questions` - Question-level data (answer key + topic codes)
14. `test_teacher_assignments` - Which teacher for which subject in test
15. `student_responses` - Per-question responses
16. `student_subtopic_mastery` - Computed mastery per subtopic (cumulative)
17. `test_results_cache` - Pre-computed rankings

**System:**
18. `notifications` - In-app notifications
19. `audit_logs` - All user actions
20. `ai_insights_cache` - Gemini response cache
21. `omr_upload_batches` - Upload history
22. `omr_unmatched_rolls` - Manual mapping queue

**Laravel defaults:**
23. `sessions`
24. `failed_jobs`
25. `personal_access_tokens`

### 2.2 Key Tables — Schema Details

#### `institutes`

```sql
CREATE TABLE institutes (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    name VARCHAR(255) NOT NULL,
    code VARCHAR(20) UNIQUE NOT NULL,
    logo_path VARCHAR(500) NULL,
    address TEXT NULL,
    phone VARCHAR(20) NULL,
    email VARCHAR(255) NULL,
    website VARCHAR(255) NULL,
    timezone VARCHAR(50) DEFAULT 'Asia/Kolkata',
    is_active BOOLEAN DEFAULT TRUE,
    subscription_tier VARCHAR(20) DEFAULT 'trial',
    student_limit INT DEFAULT 500,
    created_at TIMESTAMP,
    updated_at TIMESTAMP
);
```

#### `users`

```sql
CREATE TABLE users (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    name VARCHAR(255) NOT NULL,
    email VARCHAR(255) UNIQUE NOT NULL,
    username VARCHAR(100) UNIQUE NOT NULL,
    password VARCHAR(255) NOT NULL,
    role ENUM('owner','academic_head','admin','sub_admin','teacher','typist') NOT NULL,
    phone VARCHAR(20) NULL,
    is_active BOOLEAN DEFAULT TRUE,
    email_verified_at TIMESTAMP NULL,
    last_login_at TIMESTAMP NULL,
    remember_token VARCHAR(100) NULL,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    INDEX idx_institute_role (institute_id, role),
    INDEX idx_institute_active (institute_id, is_active)
);
```

#### `courses`

```sql
CREATE TABLE courses (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    name VARCHAR(100) NOT NULL,  -- e.g., "NEET-2026"
    code VARCHAR(20) NOT NULL,   -- e.g., "NEET"
    exam_type ENUM('NEET','JEE_MAIN','JEE_ADVANCED','OTHER') NOT NULL,
    target_year YEAR NOT NULL,
    duration_months INT NOT NULL, -- 12, 24, etc.
    total_questions INT NULL,     -- e.g., 180 for NEET
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    INDEX idx_institute (institute_id),
    INDEX idx_exam_type (exam_type)
);
```

#### `batches`

```sql
CREATE TABLE batches (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    course_id BIGINT UNSIGNED NOT NULL,
    name VARCHAR(100) NOT NULL,  -- "Morning Batch A"
    code VARCHAR(20) NULL,        -- "NEET-M-A"
    timing_label VARCHAR(50) NULL, -- "8AM-1PM"
    capacity INT DEFAULT 50,
    start_date DATE NULL,
    end_date DATE NULL,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    FOREIGN KEY (course_id) REFERENCES courses(id) ON DELETE CASCADE,
    INDEX idx_institute_course (institute_id, course_id)
);
```

#### `students`

```sql
CREATE TABLE students (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    batch_id BIGINT UNSIGNED NOT NULL,
    
    -- Identifiers
    roll_number VARCHAR(30) NOT NULL,  -- For OMR matching
    enrollment_number VARCHAR(30) NULL,
    
    -- Personal
    name VARCHAR(255) NOT NULL,
    father_name VARCHAR(255) NULL,
    mother_name VARCHAR(255) NULL,
    date_of_birth DATE NULL,
    gender ENUM('M','F','O') NULL,
    
    -- Contact
    phone VARCHAR(20) NULL,
    parent_phone VARCHAR(20) NULL,
    email VARCHAR(255) NULL,
    address TEXT NULL,
    
    -- Academic
    admission_date DATE NULL,
    medium ENUM('english','hindi') DEFAULT 'english',
    previous_score DECIMAL(5,2) NULL, -- From entrance test
    
    -- Status
    is_active BOOLEAN DEFAULT TRUE,
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    FOREIGN KEY (batch_id) REFERENCES batches(id) ON DELETE CASCADE,
    UNIQUE KEY unq_roll_institute (institute_id, roll_number),
    INDEX idx_batch (batch_id),
    INDEX idx_institute_active (institute_id, is_active)
);
```

#### `subjects`

```sql
CREATE TABLE subjects (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    name VARCHAR(100) NOT NULL,     -- "Physics"
    code CHAR(1) NOT NULL,          -- "P"
    exam_type ENUM('NEET','JEE','BOTH') DEFAULT 'BOTH',
    display_order INT DEFAULT 0,
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    UNIQUE KEY unq_code_institute (institute_id, code)
);
```

#### `curriculum_nodes`

```sql
CREATE TABLE curriculum_nodes (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    subject_id BIGINT UNSIGNED NOT NULL,
    parent_id BIGINT UNSIGNED NULL,  -- For tree structure
    
    -- Hierarchy
    level ENUM('chapter','topic','subtopic') NOT NULL,
    name VARCHAR(255) NOT NULL,
    code VARCHAR(20) NOT NULL,       -- "P-MEC-KIN-01"
    full_code VARCHAR(30) NOT NULL,  -- Pre-computed full path
    
    -- Meta
    display_order INT DEFAULT 0,
    weightage DECIMAL(5,2) NULL,     -- % of exam (for NEET/JEE)
    difficulty ENUM('easy','medium','hard') NULL,
    
    is_active BOOLEAN DEFAULT TRUE,
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    FOREIGN KEY (subject_id) REFERENCES subjects(id) ON DELETE CASCADE,
    FOREIGN KEY (parent_id) REFERENCES curriculum_nodes(id) ON DELETE CASCADE,
    UNIQUE KEY unq_code_institute (institute_id, full_code),
    INDEX idx_subject_level (subject_id, level),
    INDEX idx_parent (parent_id)
);
```

#### `tests`

```sql
CREATE TABLE tests (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    course_id BIGINT UNSIGNED NOT NULL,
    
    -- Identification
    test_code VARCHAR(50) UNIQUE NOT NULL, -- "NEET-MOCK-2026-01"
    name VARCHAR(255) NOT NULL,
    
    -- Metadata
    test_type ENUM('dpt','weekly','mock','flt','chapter','revision') NOT NULL,
    test_date DATE NOT NULL,
    duration_minutes INT NOT NULL,
    total_questions INT NOT NULL,
    total_marks INT NOT NULL,
    
    -- Marking scheme
    correct_marks DECIMAL(4,2) DEFAULT 4,
    incorrect_marks DECIMAL(4,2) DEFAULT -1,
    unattempted_marks DECIMAL(4,2) DEFAULT 0,
    
    -- Lifecycle
    status ENUM('draft','blueprint_ready','conducted','responses_uploaded','analyzed','archived') DEFAULT 'draft',
    created_by BIGINT UNSIGNED NOT NULL,  -- Typist user_id
    
    -- Timestamps
    conducted_at TIMESTAMP NULL,
    responses_uploaded_at TIMESTAMP NULL,
    analyzed_at TIMESTAMP NULL,
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    FOREIGN KEY (course_id) REFERENCES courses(id) ON DELETE CASCADE,
    FOREIGN KEY (created_by) REFERENCES users(id),
    INDEX idx_institute_status (institute_id, status),
    INDEX idx_test_date (test_date)
);
```

#### `test_questions`

```sql
CREATE TABLE test_questions (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    test_id BIGINT UNSIGNED NOT NULL,
    
    -- Question metadata (no question TEXT stored)
    question_number INT NOT NULL,  -- 1 to 180
    subject_id BIGINT UNSIGNED NOT NULL,
    curriculum_node_id BIGINT UNSIGNED NOT NULL,  -- Points to subtopic
    topic_code VARCHAR(30) NOT NULL, -- Denormalized for speed
    
    -- Answer
    correct_answer CHAR(1) NOT NULL, -- A/B/C/D or for integer: stored as string
    answer_type ENUM('mcq','integer','numerical') DEFAULT 'mcq',
    
    -- Marking (can override test-level)
    correct_marks DECIMAL(4,2) NULL,
    incorrect_marks DECIMAL(4,2) NULL,
    
    -- Meta
    difficulty ENUM('easy','medium','hard') NULL,
    expected_time_seconds INT NULL,
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (test_id) REFERENCES tests(id) ON DELETE CASCADE,
    FOREIGN KEY (subject_id) REFERENCES subjects(id),
    FOREIGN KEY (curriculum_node_id) REFERENCES curriculum_nodes(id),
    UNIQUE KEY unq_test_qnum (test_id, question_number),
    INDEX idx_test_subject (test_id, subject_id),
    INDEX idx_curriculum (curriculum_node_id)
);
```

#### `test_teacher_assignments`

```sql
CREATE TABLE test_teacher_assignments (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    test_id BIGINT UNSIGNED NOT NULL,
    teacher_id BIGINT UNSIGNED NOT NULL,
    subject_id BIGINT UNSIGNED NOT NULL,
    
    -- Question range for this teacher
    question_start INT NOT NULL,  -- e.g., 1
    question_end INT NOT NULL,    -- e.g., 45
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (test_id) REFERENCES tests(id) ON DELETE CASCADE,
    FOREIGN KEY (teacher_id) REFERENCES users(id),
    FOREIGN KEY (subject_id) REFERENCES subjects(id),
    UNIQUE KEY unq_test_subject (test_id, subject_id),
    INDEX idx_teacher (teacher_id)
);
```

#### `student_responses`

```sql
CREATE TABLE student_responses (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    test_id BIGINT UNSIGNED NOT NULL,
    student_id BIGINT UNSIGNED NOT NULL,
    test_question_id BIGINT UNSIGNED NOT NULL,
    
    -- Response
    submitted_answer CHAR(1) NULL,  -- NULL = unattempted
    is_correct BOOLEAN NULL,
    marks_awarded DECIMAL(4,2) DEFAULT 0,
    
    -- For analysis
    time_taken_seconds INT NULL,  -- If OMR captures timing
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (test_id) REFERENCES tests(id) ON DELETE CASCADE,
    FOREIGN KEY (student_id) REFERENCES students(id) ON DELETE CASCADE,
