## 13. OMR RESPONSE PROCESSING

### 13.1 OmrProcessingService

**Location:** `app/Services/OmrProcessingService.php`

**Key methods:**

```php
class OmrProcessingService
{
    public function processUpload(int $testId, string $excelPath): array
    {
        // Step 1: Parse Excel
        $rows = $this->parseExcel($excelPath);
        
        // Step 2: Validate structure
        $validation = $this->validate($testId, $rows);
        if (!$validation['valid']) {
            return ['status' => 'validation_failed', 'errors' => $validation['errors']];
        }
        
        // Step 3: Match roll numbers
        $matchResults = $this->matchRollNumbers($rows);
        if ($matchResults['unmatched_count'] > 0) {
            return [
                'status' => 'pending_manual_match',
                'unmatched' => $matchResults['unmatched']
            ];
        }
        
        // Step 4: Create responses
        $this->createResponses($testId, $matchResults['matched']);
        
        // Step 5: Calculate scores
        $this->calculateScores($testId);
        
        // Step 6: Trigger mastery update
        app(MasteryCalculationService::class)->updateForTest($testId);
        
        // Step 7: Calculate ranks
        app(RankCalculationService::class)->calculateRanks($testId);
        
        // Step 8: Send notifications
        app(NotificationService::class)->notifyTestAnalyzed($testId);
        
        // Step 9: Update test status
        Test::find($testId)->update([
            'status' => 'analyzed',
            'analyzed_at' => now()
        ]);
        
        return ['status' => 'success'];
    }
    
    private function matchRollNumbers(array $rows): array { ... }
    private function createResponses(int $testId, array $matched): void { ... }
    private function calculateScores(int $testId): void { ... }
}
