    -- Template used
    template_used VARCHAR(50) NULL, -- 'response_manager', 'student_manager', 'custom'
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE,
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    UNIQUE KEY unq_user (user_id)
);
```

#### `omr_upload_batches`

```sql
CREATE TABLE omr_upload_batches (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    test_id BIGINT UNSIGNED NOT NULL,
    uploaded_by BIGINT UNSIGNED NOT NULL, -- Sub-admin user_id
    
    -- Upload details
    file_path VARCHAR(500) NOT NULL,
    file_name VARCHAR(255) NOT NULL,
    file_size INT NOT NULL,
    
    -- Processing
    status ENUM('uploaded','validating','matching','completed','failed') DEFAULT 'uploaded',
    total_rows INT NULL,
    matched_rows INT NULL,
    unmatched_rows INT NULL,
    
    -- Errors
    error_log TEXT NULL,
    validation_errors JSON NULL,
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    completed_at TIMESTAMP NULL,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    FOREIGN KEY (test_id) REFERENCES tests(id),
    FOREIGN KEY (uploaded_by) REFERENCES users(id)
);
```

#### `audit_logs`

```sql
CREATE TABLE audit_logs (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    user_id BIGINT UNSIGNED NULL, -- NULL for system actions
    
    -- What happened
    action VARCHAR(100) NOT NULL, -- 'test.created', 'student.updated', etc.
    entity_type VARCHAR(50) NULL, -- 'Test', 'Student', etc.
    entity_id BIGINT UNSIGNED NULL,
    
    -- Details
    description TEXT NULL,
    changes JSON NULL, -- Before/after for updates
    metadata JSON NULL,
    
    -- Context
    ip_address VARCHAR(45) NULL,
    user_agent VARCHAR(500) NULL,
    
    created_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE SET NULL,
    INDEX idx_institute_created (institute_id, created_at),
    INDEX idx_user (user_id),
    INDEX idx_action (action)
);
```

