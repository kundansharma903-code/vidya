    UNIQUE KEY unq_student_question (student_id, test_question_id),
    INDEX idx_test_student (test_id, student_id)
);
```

#### `student_subtopic_mastery`

```sql
CREATE TABLE student_subtopic_mastery (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    institute_id BIGINT UNSIGNED NOT NULL,
    student_id BIGINT UNSIGNED NOT NULL,
    curriculum_node_id BIGINT UNSIGNED NOT NULL, -- Subtopic
    subject_id BIGINT UNSIGNED NOT NULL,
    
    -- Cumulative metrics
    total_questions_attempted INT DEFAULT 0,
    total_questions_correct INT DEFAULT 0,
    total_marks_earned DECIMAL(8,2) DEFAULT 0,
    total_marks_possible DECIMAL(8,2) DEFAULT 0,
    
    -- Computed
    mastery_percentage DECIMAL(5,2) DEFAULT 0, -- (correct/attempted)*100
    accuracy_percentage DECIMAL(5,2) DEFAULT 0, -- Same for coaching
    
    -- Trend
    last_test_score DECIMAL(5,2) NULL,
    last_updated_at TIMESTAMP NULL,
    
    created_at TIMESTAMP,
    updated_at TIMESTAMP,
    
    FOREIGN KEY (institute_id) REFERENCES institutes(id) ON DELETE CASCADE,
    FOREIGN KEY (student_id) REFERENCES students(id) ON DELETE CASCADE,
    FOREIGN KEY (curriculum_node_id) REFERENCES curriculum_nodes(id),
    FOREIGN KEY (subject_id) REFERENCES subjects(id),
    UNIQUE KEY unq_student_subtopic (student_id, curriculum_node_id),
    INDEX idx_student_subject (student_id, subject_id),
    INDEX idx_mastery (mastery_percentage)
);
```

#### `sub_admin_permissions`

```sql
CREATE TABLE sub_admin_permissions (
    id BIGINT UNSIGNED PRIMARY KEY AUTO_INCREMENT,
    user_id BIGINT UNSIGNED NOT NULL,
